APP_HOST=0.0.0.0
APP_PORT=8088
LOG_LEVEL=INFO
OCTOPRINT_BASE_URL=http://192.168.2.59
OCTOPRINT_WEBCAM_URL=http://192.168.2.59/webcam/?action=stream
YOUTUBE_RTMPS_URL=rtmps://a.rtmps.youtube.com/live2
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
# YouTube Live: mindestens 15 FPS (besser 30), 720p ca. 2500k-4000k
VIDEO_FPS=15
VIDEO_BITRATE=2500k
AUDIO_BITRATE=128k
STREAM_AUTO_RESUME=true
STREAM_RESUME_DELAY_SECONDS=45
STREAM_AUTO_RESTART=true
STREAM_RESTART_DELAY_SECONDS=10
STREAM_RESTART_MAX_ATTEMPTS=0
AUTO_START_ON_PRINT=true
AUTO_PRINT_POLL_SECONDS=10
OVERLAY_ENABLED=true
OVERLAY_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
OVERLAY_FONT_SIZE=28
OVERLAY_FONT_COLOR=white
OVERLAY_X=24
OVERLAY_Y=24
OVERLAY_INTERVAL_SECONDS=5
OVERLAY_LOGO_ENABLED=true
OVERLAY_LOGO_PATH=assets/logo.png
OVERLAY_LOGO_WIDTH=120
OVERLAY_LOGO_X=W-w-24
OVERLAY_LOGO_Y=24

# Secrets gehören in .env.secrets (siehe .env.secrets.example)
